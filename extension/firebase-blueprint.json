{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User's basic resume information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "summary": { "type": "string" },
        "experience": { "type": "string", "description": "Work experience details" },
        "education": { "type": "string", "description": "Education details" },
        "skills": { "type": "string", "description": "Comma separated skills" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    }
  }
}
